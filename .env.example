# Web app URL for POST /api/lead → Apps Script (must be script.google.com/.../exec, not the spreadsheet link).
LEAD_WEB_APP_URL=
# Aliases (same value; any one is enough on the server):
# APPS_SCRIPT_LEAD_URL=
# Browser fallback if /api/lead fails — use same /exec URL; exposed in client JS:
# NEXT_PUBLIC_LEAD_WEB_APP_URL=
# NEXT_PUBLIC_APPS_SCRIPT_LEAD_URL=
